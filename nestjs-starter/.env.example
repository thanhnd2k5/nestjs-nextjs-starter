# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=nestjs-starter
APP_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# API_PREFIX=api

# ─── Swagger (defaults: on in dev/test, off in production) ─
# SWAGGER_ENABLED=true

# ─── Feature flags (optional modules) ──────────────────
# Cross-deps: FEATURE_BULLMQ requires FEATURE_REDIS
#             FEATURE_AUTH requires FEATURE_PRISMA
FEATURE_PRISMA=false
FEATURE_REDIS=false
FEATURE_BULLMQ=false
FEATURE_AUTH=false

# ─── Prisma (required when FEATURE_PRISMA=true) ────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nestjs_starter

# ─── Redis (required when FEATURE_REDIS=true) ──────────
# REDIS_URL=redis://localhost:6379

# ─── Auth (required when FEATURE_AUTH=true) ────────────
# JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
# JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption (required in production) ───────────────
# ENCRYPTION_SECRET=change-me-encryption-secret-32chars

# ─── Rate limiting ─────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
