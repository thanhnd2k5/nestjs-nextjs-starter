# ─── App ───────────────────────────────────────────────
NODE_ENV=development
APP_NAME=nextjs-starter
APP_VERSION=1.0.0

# ─── API ───────────────────────────────────────────────
# NestJS URL when running full-stack (nestjs-starter on PORT=3001)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_LOCALE=vi

# ─── Feature flags (optional modules) ──────────────────
# Cross-deps: FEATURE_AUTH requires NEXT_PUBLIC_API_URL or FEATURE_API_PROXY + API_PROXY_TARGET
#             FEATURE_API_PROXY requires API_PROXY_TARGET (dev only — blocked in production)
FEATURE_AUTH=false
FEATURE_API_PROXY=false
FEATURE_OFFLINE=false

# i18n is core (always on) — change locale via NEXT_PUBLIC_DEFAULT_LOCALE above

# ─── API proxy (required when FEATURE_API_PROXY=true) ──
# Proxies /api/* from Next.js → NestJS (avoids CORS in dev)
# API_PROXY_TARGET=http://localhost:3001
